# SysRoar Agent Configuration
# Copy this file to .env and fill in your details.

# API Endpoints
SYSROAR_API_URL=http://localhost:8000/api/telemetry/ingest/
SYSROAR_CONFIG_URL=http://localhost:8000/api/telemetry/config/

# Authentication & Identification
# Obtain the API Token from the Django admin (DRF Token Authentication)
SYSROAR_API_TOKEN=your_drf_auth_token_here
SYSROAR_SERVER_ID=your_server_uuid_here
SYSROAR_COMPANY_ID=your_company_uuid_here

# Telemetry Settings
SYSROAR_TELEMETRY_CADENCE=30

# Logstash / Syslog Settings
# Host can be the IP/Hostname of the Logstash server
SYSROAR_LOGSTASH_HOST=localhost
SYSROAR_LOGSTASH_PORT=5000
